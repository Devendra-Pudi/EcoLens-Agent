{
  "version": 2,
  "builds": [
    {
      "src": "fastapi-app/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "fastapi-app/app.py"
    },
    {
      "src": "/health",
      "dest": "fastapi-app/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "GOOGLE_API_KEY": "@google_api_key"
  }
}
